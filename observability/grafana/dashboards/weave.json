{
  "uid": "weave-main",
  "title": "weave — convergence & ingest",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "timezone": "browser",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "active sessions",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } } },
      "targets": [ { "refId": "A", "expr": "sum(weave_sessions_active)" } ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "active rooms",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [ { "refId": "A", "expr": "sum(weave_rooms_active)" } ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "ingest rate (ops/s)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "targets": [ { "refId": "A", "expr": "sum(rate(weave_ops_ingested_total[1m])) + sum(rate(weave_text_ops_ingested_total[1m]))" } ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "ops ingested (total)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "text" } } },
      "targets": [ { "refId": "A", "expr": "sum(weave_ops_ingested_total) + sum(weave_text_ops_ingested_total)" } ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "op ingest rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 18, "lineWidth": 2 } } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(weave_ops_ingested_total[1m]))", "legendFormat": "canvas ops/s" },
        { "refId": "B", "expr": "sum(rate(weave_text_ops_ingested_total[1m]))", "legendFormat": "text ops/s" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "ingest latency (persist)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum(rate(weave_ingest_seconds_bucket[1m])) by (le))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum(rate(weave_ingest_seconds_bucket[1m])) by (le))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum(rate(weave_ingest_seconds_bucket[1m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP request latency p95",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[1m])) by (le, uri))", "legendFormat": "{{uri}}" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "JVM heap used",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 14, "lineWidth": 2 } } },
      "targets": [
        { "refId": "A", "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "heap used" }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "snapshots written",
      "description": "room snapshots materialised by the sweeper (canvas_snapshot upserts)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "orange" } } },
      "targets": [ { "refId": "A", "expr": "sum(weave_snapshot_writes_total)" } ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "cold-start tail (max ops)",
      "description": "ops folded beyond the snapshot on a cold room load — bounded by the snapshot cadence, not the room lifetime",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "yellow" } } },
      "targets": [ { "refId": "A", "expr": "max(weave_replay_tail_ops_max)" } ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "snapshot refresh / cold-start replay",
      "description": "time to fold+persist a room snapshot, and to rebuild a room on cold start (snapshot + tail)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } } },
      "targets": [
        { "refId": "A", "expr": "weave_snapshot_refresh_seconds_max", "legendFormat": "snapshot refresh (max)" },
        { "refId": "B", "expr": "weave_replay_seconds_max", "legendFormat": "cold-start replay (max)" }
      ]
    }
  ]
}
